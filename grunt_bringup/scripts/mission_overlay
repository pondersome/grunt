#!/usr/bin/env python3
"""
mission_overlay — publishes a mission's GPS waypoints as GeoJSON for
Foxglove's Map panel.

Standalone node (not a BT leaf). Subscribes to a `show_mission` topic;
on each message, loads the named mission from missions_dir and emits
its path on a latched `geojson` topic. Empty message clears.

Foxglove's Map panel auto-detects foxglove_msgs/GeoJSON topics and
renders their geometry (Points, LineStrings, Polygons) on top of the
basemap tiles. This is the clean native path for a mission-path
overlay — richer than a single NavSatFix marker, no client-side
config once the topic is discovered.

Intentionally single-mission at a time: pub an empty payload (or
pub a new name) to swap. If multi-mission comparison becomes useful
later, add a per-mission topic suffix.

Pose missions (frame != 'gps') are refused — Foxglove's Map panel
projects into WGS84 tiles; an odom-frame pose has no geo meaning.
Pose missions belong on the 3D panel with a MarkerArray overlay
(separate tool).
"""
import glob
import json
import os

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSDurabilityPolicy, QoSProfile
from std_msgs.msg import String
from std_srvs.srv import Trigger
import yaml

# foxglove_msgs is apt-installable as ros-jazzy-foxglove-msgs. Import
# lazily with a clear error so the package check points at the fix.
try:
    from foxglove_msgs.msg import GeoJSON
except ImportError as exc:
    raise SystemExit(
        'foxglove_msgs not available. Install with:\n'
        '  sudo apt install ros-jazzy-foxglove-msgs\n'
        f'Original error: {exc}')


class MissionOverlay(Node):
    def __init__(self):
        super().__init__('mission_overlay')

        self.declare_parameter('missions_dir', '')
        self.declare_parameter('show_topic', '~/show_mission')
        self.declare_parameter('geojson_topic', '~/geojson')
        self.declare_parameter('selected_mission_topic', '~/selected_mission')
        self.declare_parameter('available_missions_topic', '~/available_missions')

        self.missions_dir = self.get_parameter('missions_dir').value
        show_topic = self.get_parameter('show_topic').value
        geojson_topic = self.get_parameter('geojson_topic').value
        selected_topic = self.get_parameter('selected_mission_topic').value
        available_topic = self.get_parameter('available_missions_topic').value

        if not self.missions_dir:
            self.get_logger().fatal(
                'missions_dir parameter is required and was empty')
            raise RuntimeError('missions_dir empty')

        # Latched so a panel that opens after the publish still sees
        # the current overlay. TRANSIENT_LOCAL depth 1 matches the
        # nav_mode pattern.
        latched_qos = QoSProfile(
            depth=1,
            durability=QoSDurabilityPolicy.TRANSIENT_LOCAL,
        )
        self.geojson_pub = self.create_publisher(
            GeoJSON, geojson_topic, latched_qos)

        # selected_mission tracks the operator's currently-displayed
        # mission name. joy_commands subscribes to it so the Home
        # button dispatches what the operator is looking at, instead
        # of always picking "latest by mtime". Empty string == no
        # selection (fall back to mtime behavior at the consumer).
        self.selected_pub = self.create_publisher(
            String, selected_topic, latched_qos)

        # available_missions: latched JSON list of mission names found
        # in missions_dir (no .yaml extension). Refreshed on every
        # cycle service call and on every show_mission so the list
        # reflects newly-recorded or newly-imported missions without
        # a node restart. Foxglove can echo it via Topic Echo for
        # debugging; the cycle services are the natural consumer.
        self.available_pub = self.create_publisher(
            String, available_topic, latched_qos)

        self.create_subscription(
            String, show_topic, self._on_show_mission, 10)

        # Cycle services let two Foxglove Call Service panels (next /
        # previous) step through the available missions in sorted
        # order. Each call: rescan the dir, advance/retreat the index,
        # republish show_mission/selected/geojson for the new pick.
        # Trigger-shaped because they have no input payload and the
        # response is just "did we advance, and to what?".
        self.create_service(
            Trigger, '~/cycle_next', self._on_cycle_next)
        self.create_service(
            Trigger, '~/cycle_previous', self._on_cycle_previous)

        # Index into the most-recent available_missions list. -1 means
        # no selection yet; first cycle_next call lands on index 0.
        self.cycle_index = -1
        self.available_missions = []

        # Seed all latched topics with empty/initial messages so late
        # subscribers see a defined state.
        self._refresh_available()
        self._publish_empty()

        self.get_logger().info(
            f'mission_overlay ready: missions_dir={self.missions_dir}, '
            f'show_topic={show_topic}, geojson_topic={geojson_topic}, '
            f'selected_mission_topic={selected_topic}, '
            f'available_missions_topic={available_topic}, '
            f'{len(self.available_missions)} missions found.')

    def _refresh_available(self):
        """Scan missions_dir for *.yaml files. Publishes a JSON-encoded
        list (sorted) on available_pub. Returns the list. Cheap (~ms
        for typical mission counts) — call on each cycle to pick up
        new YAMLs without polling."""
        try:
            paths = glob.glob(os.path.join(self.missions_dir, '*.yaml'))
        except OSError as e:
            self.get_logger().warn(f'available scan failed: {e}')
            paths = []
        names = sorted(os.path.splitext(os.path.basename(p))[0] for p in paths)
        self.available_missions = names
        msg = String()
        # JSON list — a Topic Echo panel renders cleanly, and the
        # format is forward-compatible for richer payloads (ts/kind/etc).
        msg.data = json.dumps(names)
        self.available_pub.publish(msg)
        return names

    def _on_show_mission(self, msg: String):
        name = msg.data.strip()
        if not name:
            self.get_logger().info('show_mission cleared')
            self.cycle_index = -1
            self._publish_empty()
            return

        # Sync the cycle index to what the operator just asked for, so
        # next/prev advance from the right starting point — even when
        # the trigger came from outside our cycle services (CLI pub,
        # bt_runner-driven set, etc.).
        names = self._refresh_available()
        if name in names:
            self.cycle_index = names.index(name)
        else:
            # Mission isn't in our directory — proceed with overlay/
            # selection but warn. Stale missions or property mismatches
            # are real situations; fail-quietly is worse than load-
            # anyway-with-warning.
            self.cycle_index = -1
            self.get_logger().warn(
                f"'{name}' not in available list ({len(names)} known). "
                'Loading anyway from missions_dir.')

        path = os.path.join(self.missions_dir, f'{name}.yaml')
        try:
            with open(path, 'r') as f:
                mission = yaml.safe_load(f)
        except OSError as e:
            self.get_logger().error(f'Mission load failed: {e}')
            return
        except yaml.YAMLError as e:
            self.get_logger().error(f'YAML parse failed: {e}')
            return

        if not isinstance(mission, dict):
            self.get_logger().error(
                f'{path}: top-level YAML is not a map')
            return

        frame = mission.get('frame')
        waypoints = mission.get('waypoints')
        if not isinstance(waypoints, list) or not waypoints:
            self.get_logger().error(
                f'{path}: waypoints missing or empty')
            return

        # Selection vs visualization are intentionally separable:
        # any valid mission becomes the operator's selection (so the
        # Home button can dispatch a pose mission too), even though
        # the GeoJSON overlay only renders GPS missions on the Map
        # panel. Pose missions get an empty GeoJSON publish so the
        # map clears any prior overlay rather than misleading the
        # operator into thinking the previous path still applies.
        self._publish_selected(name)

        if frame != 'gps':
            self.get_logger().info(
                f"Selected pose mission '{name}' (frame='{frame}'); "
                'clearing Map overlay (pose missions render on the 3D panel).')
            self._publish_empty_geojson()
            return

        geojson = self._build_geojson(name, mission, waypoints)
        self._publish_geojson(geojson)
        self.get_logger().info(
            f"Published overlay for '{name}' ({len(waypoints)} waypoints)")

    def _build_geojson(self, name, mission, waypoints):
        # GeoJSON coordinate order is [lon, lat, alt] — opposite of our
        # YAML's lat/lon keys. Same gotcha as KML; keep the conversion
        # pinned to one place.
        line_coords = []
        for wp in waypoints:
            try:
                lon = float(wp['lon'])
                lat = float(wp['lat'])
            except (KeyError, TypeError, ValueError):
                self.get_logger().warn(f'Skipping malformed waypoint: {wp}')
                continue
            coord = [lon, lat]
            if 'alt' in wp:
                try:
                    coord.append(float(wp['alt']))
                except (TypeError, ValueError):
                    pass
            line_coords.append(coord)

        features = [
            {
                'type': 'Feature',
                'properties': {
                    'name': name,
                    'role': 'path',
                    'description': mission.get('description', ''),
                },
                'geometry': {
                    'type': 'LineString',
                    'coordinates': line_coords,
                },
            }
        ]

        # Start / end markers so the path has visible endpoints and
        # direction is readable at a glance in the panel.
        if line_coords:
            features.append({
                'type': 'Feature',
                'properties': {'name': f'{name} start', 'role': 'start'},
                'geometry': {'type': 'Point', 'coordinates': line_coords[0]},
            })
        if len(line_coords) >= 2:
            features.append({
                'type': 'Feature',
                'properties': {'name': f'{name} end', 'role': 'end'},
                'geometry': {'type': 'Point', 'coordinates': line_coords[-1]},
            })

        return {'type': 'FeatureCollection', 'features': features}

    def _publish_geojson(self, geojson_obj):
        msg = GeoJSON()
        msg.geojson = json.dumps(geojson_obj, separators=(',', ':'))
        self.geojson_pub.publish(msg)

    def _publish_empty_geojson(self):
        self._publish_geojson({'type': 'FeatureCollection', 'features': []})

    def _publish_selected(self, name: str):
        msg = String()
        msg.data = name
        self.selected_pub.publish(msg)

    def _publish_empty(self):
        # Empty GeoJSON + empty selection. Used at startup so latched
        # subscribers immediately see a defined state, and on explicit
        # clear (empty show_mission payload).
        self._publish_empty_geojson()
        self._publish_selected('')

    def _show_by_index(self, idx: int) -> str:
        """Refresh the list, clamp idx, run the selection plumbing,
        return the chosen name (or '' on empty list)."""
        names = self._refresh_available()
        if not names:
            self.get_logger().warn(
                'No missions in directory — cycle has nothing to advance to.')
            return ''
        # Wrap on either end so cycling from end → start (and vice
        # versa) is one click rather than dead-ending the operator.
        idx = idx % len(names)
        self.cycle_index = idx
        chosen = names[idx]
        # Reuse the existing show pipeline by publishing internally —
        # avoids duplicating the load-and-publish flow per entry point.
        synthetic = String()
        synthetic.data = chosen
        self._on_show_mission(synthetic)
        return chosen

    def _on_cycle_next(self, request, response):
        chosen = self._show_by_index(self.cycle_index + 1)
        response.success = bool(chosen)
        response.message = chosen or 'no missions available'
        return response

    def _on_cycle_previous(self, request, response):
        # First-ever cycle_previous (cycle_index == -1) lands on the
        # last mission, which feels right for "step backward from
        # nothing-selected".
        chosen = self._show_by_index(self.cycle_index - 1)
        response.success = bool(chosen)
        response.message = chosen or 'no missions available'
        return response


def main(args=None):
    rclpy.init(args=args)
    node = MissionOverlay()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()


if __name__ == '__main__':
    main()
