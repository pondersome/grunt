#!/usr/bin/env python3
"""
Joystick command node: e-stop, macro execution, and future button utilities.

E-stop (B/button 1):
  Locks ALL velocity sources via twist_mux at priority 255 and cancels
  any active Nav2 missions. Engage-only — release is exclusively via
  the deadman button after releasing it first.

Home button (button 12):
  Default: finds the most recently modified mission YAML in missions_dir
  and publishes its name to bt_runner/start_mission via native rclpy
  publisher (no subprocess, no DDS discovery race).
  Override: if macro_cmd is set (via parameter or ~/set_macro topic),
  executes that shell command instead. Useful for field debugging or
  non-mission automation.
"""
import glob
import os
import subprocess

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSDurabilityPolicy, QoSProfile
from sensor_msgs.msg import Joy
from std_msgs.msg import Bool, String
from std_srvs.srv import Trigger


class JoyCommands(Node):
    def __init__(self):
        super().__init__('joy_commands')

        self.declare_parameter('estop_button', 1)    # B button (red)
        self.declare_parameter('deadman_button', 6)   # left bumper
        self.declare_parameter('macro_button', 12)    # Home button
        self.declare_parameter('reset_cal_button', 11)  # Menu (small) — reset localization calibration
        self.declare_parameter('prefix', 'grunt1')   # robot namespace prefix
        # Double-tap of estop within this window (seconds), while estop
        # is already active, fires the bt_runner ~/reset_mission service
        # — clears next_waypoint_idx_ and forces auto-direction on the
        # next dispatch. First tap is the normal halt; second tap is
        # the escalation to "abandon mission progress entirely."
        self.declare_parameter('reset_mission_double_tap_window_s', 1.5)
        self.estop_button = self.get_parameter('estop_button').value
        self.deadman_button = self.get_parameter('deadman_button').value
        self.macro_button = self.get_parameter('macro_button').value
        self.reset_cal_button = self.get_parameter('reset_cal_button').value
        self.reset_mission_window = float(
            self.get_parameter('reset_mission_double_tap_window_s').value)
        prefix = self.get_parameter('prefix').value

        self.estop_active = False
        self.estop_button_prev = False
        self.deadman_prev = False
        self.deadman_released_since_estop = False
        self.macro_button_prev = False
        self.reset_cal_button_prev = False
        # Monotonic clock seconds of the most recent estop button rising
        # edge. Used to detect double-tap → reset_mission.
        self.last_estop_press_mono_s = -1e9

        # Home button behavior (priority order):
        #   1. macro_cmd set → run that shell command.
        #   2. mission_overlay has a selection → dispatch that mission.
        #   3. Fall back to latest YAML by mtime.
        # macro_cmd is settable via parameter or ~/set_macro topic at
        # runtime. The selection comes from mission_overlay's latched
        # ~/selected_mission topic — mission_overlay owns "what's the
        # operator looking at?" and we just consume it.
        self.declare_parameter('missions_dir', '')
        self.declare_parameter('macro_cmd', '')
        self.declare_parameter(
            'selected_mission_topic',
            f'/{prefix}/mission_overlay/selected_mission')
        self.missions_dir = self.get_parameter('missions_dir').value
        self.macro_cmd = self.get_parameter('macro_cmd').value
        selected_topic = self.get_parameter('selected_mission_topic').value
        self.macro_process = None
        self.selected_mission_name = ''

        # Publisher to twist_mux e-stop lock
        self.estop_pub = self.create_publisher(Bool, 'estop/joystick', 10)

        # Publisher for mission dispatch — same DDS participant as this
        # node, so bt_runner's subscription is already matched. No
        # discovery race.
        self.start_mission_pub = self.create_publisher(
            String, 'bt_runner/start_mission', 10)

        # Subscribe to joystick and optional macro override
        self.create_subscription(Joy, 'joy', self._joy_cb, 10)
        self.create_subscription(String, '~/set_macro', self._set_macro_cb, 10)

        # Latched subscription — must match mission_overlay's
        # TRANSIENT_LOCAL publisher QoS to receive the latched value
        # if we start after the overlay node.
        latched_qos = QoSProfile(
            depth=1,
            durability=QoSDurabilityPolicy.TRANSIENT_LOCAL,
        )
        self.create_subscription(
            String, selected_topic, self._on_selected_mission, latched_qos)

        # Behaviors-layer resume service — the deadman-acknowledge release
        # path calls this so the BT re-arms and returns to whatever branch
        # was interrupted (or Idle if nothing). If the behaviors stack
        # isn't running, the call will fail silently — that's fine: the
        # twist_mux unlock still frees the wheels.
        self.resume_client = self.create_client(Trigger, 'bt_runner/resume')

        # Mission reset — bumped by a second estop press while estop is
        # already active. Clears next_waypoint_idx_ + last_failure_reason
        # so the next dispatch runs auto-direction fresh.
        self.reset_mission_client = self.create_client(
            Trigger, 'bt_runner/reset_mission')

        # Calibration reset — clears the localization supervisor's
        # heading/datum state so it restarts the init sequence. Triggered
        # by the Menu (small) button so an accidental press is unlikely.
        self.reset_cal_client = self.create_client(
            Trigger, 'localization_supervisor/reset_calibration')

        self.get_logger().info(
            f'Joy commands ready (estop=button {self.estop_button}, '
            f'mission=button {self.macro_button}, deadman=button {self.deadman_button}, '
            f'reset_cal=button {self.reset_cal_button}, '
            f'missions_dir={self.missions_dir or "(not set)"})')

    def _joy_cb(self, msg: Joy):
        # Read button states
        estop_pressed = (self.estop_button < len(msg.buttons) and
                         bool(msg.buttons[self.estop_button]))
        deadman_pressed = (self.deadman_button < len(msg.buttons) and
                           bool(msg.buttons[self.deadman_button]))

        # E-stop button: rising edge engages lock. Never releases via this
        # button — panic-pressing the button repeatedly must not unlock.
        # Re-pressing while already locked re-publishes True (idempotent
        # reinforcement against a dropped first message). Release is
        # exclusively via the deadman-acknowledge path below.
        #
        # Double-tap escalation: a second press within
        # `reset_mission_double_tap_window_s` of the first, while estop
        # is already active, fires the mission-reset service. Lets the
        # operator say "stop AND throw away mission progress" without
        # needing a terminal.
        if estop_pressed and not self.estop_button_prev:
            now_mono = self.get_clock().now().nanoseconds * 1e-9
            elapsed = now_mono - self.last_estop_press_mono_s
            was_active_before_press = self.estop_active
            self._activate_estop()
            if (was_active_before_press
                    and elapsed <= self.reset_mission_window):
                self.get_logger().info(
                    f'E-stop double-tap detected ({elapsed:.2f}s) — '
                    f'requesting mission reset')
                self._request_reset_mission()
            self.last_estop_press_mono_s = now_mono

        # Deadman can release e-stop, but ONLY if:
        #   1. E-stop is active
        #   2. Deadman was released at least once since e-stop activated
        #      (prevents immediate unlock if operator was holding deadman
        #       when they hit e-stop)
        #   3. Deadman is now being pressed (rising edge)
        if self.estop_active:
            if not deadman_pressed:
                self.deadman_released_since_estop = True
            elif (deadman_pressed and not self.deadman_prev and
                  self.deadman_released_since_estop):
                self._release_estop('deadman acknowledge')

        # Home button: rising edge. macro_cmd > selected mission > latest by mtime.
        macro_pressed = (self.macro_button < len(msg.buttons) and
                         bool(msg.buttons[self.macro_button]))
        if macro_pressed and not self.macro_button_prev:
            if self.macro_cmd:
                self._execute_macro()
            else:
                self._dispatch_mission()

        # Menu (small) button: rising edge → request calibration reset.
        reset_cal_pressed = (self.reset_cal_button < len(msg.buttons) and
                             bool(msg.buttons[self.reset_cal_button]))
        if reset_cal_pressed and not self.reset_cal_button_prev:
            self._request_reset_calibration()

        self.estop_button_prev = estop_pressed
        self.deadman_prev = deadman_pressed
        self.macro_button_prev = macro_pressed
        self.reset_cal_button_prev = reset_cal_pressed

    def _activate_estop(self):
        self.estop_active = True
        self.deadman_released_since_estop = False

        lock_msg = Bool()
        lock_msg.data = True
        self.estop_pub.publish(lock_msg)

        self.get_logger().warn('E-STOP ACTIVATED — all velocity locked')
        # Mission lifecycle is owned by the BT layer (grunt_behaviors).
        # When the BT's HunkerDown branch engages, the mission branch is
        # halted; on resume it re-enters from blackboard state. No
        # imperative action-cancel needed from here.

    def _release_estop(self, source: str):
        self.estop_active = False
        self.deadman_released_since_estop = False

        lock_msg = Bool()
        lock_msg.data = False
        self.estop_pub.publish(lock_msg)

        self.get_logger().info(f'E-stop released via {source} — velocity unlocked')

        # Also kick the behaviors layer to re-arm so any interrupted
        # branch (e.g., mission execution) can resume. Non-blocking:
        # we don't wait for the response. If the behaviors stack isn't
        # running, the call will be queued with no server to pick it
        # up — eventually the client gives up, which is fine since
        # velocity control is already unlocked at this point.
        if self.resume_client.service_is_ready():
            future = self.resume_client.call_async(Trigger.Request())
            future.add_done_callback(self._on_resume_response)
        else:
            self.get_logger().debug(
                'bt_runner/resume service not available — skipping BT re-arm')

    def _on_resume_response(self, future):
        try:
            response = future.result()
            if response.success:
                self.get_logger().info(f'BT re-armed: {response.message}')
            else:
                self.get_logger().warn(f'BT resume refused: {response.message}')
        except Exception as e:
            self.get_logger().warn(f'BT resume call failed: {e}')

    def _on_selected_mission(self, msg: String):
        """mission_overlay tells us which mission the operator is looking at.
        Empty string means no selection (fall back to mtime at dispatch time)."""
        new_selection = msg.data.strip()
        if new_selection != self.selected_mission_name:
            if new_selection:
                self.get_logger().info(
                    f'Selected mission updated: {new_selection}')
            else:
                self.get_logger().info(
                    'Selected mission cleared — Home will dispatch latest by mtime')
        self.selected_mission_name = new_selection

    def _dispatch_mission(self):
        """Dispatch the operator's selected mission if any, else the most
        recently modified mission YAML in missions_dir."""
        if self.selected_mission_name:
            msg = String()
            msg.data = self.selected_mission_name
            self.start_mission_pub.publish(msg)
            self.get_logger().info(
                f'Dispatched selected mission: {self.selected_mission_name}')
            return

        if not self.missions_dir:
            self.get_logger().warn(
                'missions_dir not configured and no mission selected — '
                'cannot dispatch')
            return

        candidates = glob.glob(os.path.join(self.missions_dir, '*.yaml'))
        if not candidates:
            self.get_logger().warn(
                f'No mission files in {self.missions_dir} '
                'and no mission selected')
            return

        latest = max(candidates, key=os.path.getmtime)
        name = os.path.splitext(os.path.basename(latest))[0]

        msg = String()
        msg.data = name
        self.start_mission_pub.publish(msg)
        self.get_logger().info(f'Dispatched latest-by-mtime mission: {name}')

    def _request_reset_calibration(self):
        if not self.reset_cal_client.service_is_ready():
            self.get_logger().warn(
                'localization_supervisor/reset_calibration not available — ignoring')
            return
        self.get_logger().info('Calibration reset requested (Menu button)')
        future = self.reset_cal_client.call_async(Trigger.Request())
        future.add_done_callback(self._on_reset_cal_response)

    def _on_reset_cal_response(self, future):
        try:
            response = future.result()
            if response.success:
                self.get_logger().info(f'Calibration reset: {response.message}')
            else:
                self.get_logger().warn(f'Calibration reset refused: {response.message}')
        except Exception as e:
            self.get_logger().warn(f'Calibration reset call failed: {e}')

    def _request_reset_mission(self):
        if not self.reset_mission_client.service_is_ready():
            self.get_logger().warn(
                'bt_runner/reset_mission not available — ignoring')
            return
        future = self.reset_mission_client.call_async(Trigger.Request())
        future.add_done_callback(self._on_reset_mission_response)

    def _on_reset_mission_response(self, future):
        try:
            response = future.result()
            if response.success:
                self.get_logger().info(f'Mission reset: {response.message}')
            else:
                self.get_logger().warn(f'Mission reset refused: {response.message}')
        except Exception as e:
            self.get_logger().warn(f'Mission reset call failed: {e}')

    def _set_macro_cb(self, msg: String):
        """Override the Home button to run a shell command instead of
        dispatching the latest mission. Publish empty string to clear
        the override and return to mission-dispatch behavior."""
        self.macro_cmd = msg.data
        if self.macro_cmd:
            self.get_logger().info(f'Macro override set: {self.macro_cmd[:80]}...')
        else:
            self.get_logger().info('Macro override cleared — Home dispatches latest mission')

    def _execute_macro(self):
        """Execute the macro_cmd shell command in a subprocess."""
        if self.macro_process and self.macro_process.poll() is None:
            self.get_logger().warn('Previous macro still running, ignoring')
            return
        self.get_logger().info(f'Executing macro: {self.macro_cmd[:80]}...')
        try:
            self.macro_process = subprocess.Popen(
                self.macro_cmd, shell=True,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        except Exception as e:
            self.get_logger().error(f'Macro execution failed: {e}')


def main(args=None):
    rclpy.init(args=args)
    node = JoyCommands()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        # Release e-stop on shutdown
        msg = Bool()
        msg.data = False
        node.estop_pub.publish(msg)
        node.destroy_node()


if __name__ == '__main__':
    main()
