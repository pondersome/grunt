#!/usr/bin/env python3
"""Mission-triggered diagnostic bag recorder.

Watches /<prefix>/bt_runner/active_behavior. When it transitions into a
mission state ("run_gps_mission" or "run_pose_mission"), spawns
`ros2 bag record` as a subprocess capturing a curated diagnostic topic
list. When the active behavior leaves the mission state, terminates
the recorder cleanly.

Bags land at: <bag_root>/<YYYY-MM-DD_HH-MM-SS>_<mission_kind>/

For ad-hoc bagging outside missions (teleop debugging, etc.) just use
`ros2 bag record -a` directly — this node is mission-scoped on purpose.
"""
import os
import signal
import subprocess
from datetime import datetime
from pathlib import Path

import rclpy
from rclpy.node import Node
from rclpy.qos import QoSProfile, QoSDurabilityPolicy, QoSReliabilityPolicy

from std_msgs.msg import String


# Curated diagnostic topic list. Prefix is substituted at startup.
#
# Namespace note: every topic published by the Nav2 stack lives under
# `/{prefix}/nav/...` (the controller_server, planner_server, etc.
# all run inside the grunt-nav@<mode>.service unit which adds a `/nav`
# sub-namespace). Topics that DON'T have `/nav/` are produced by nodes
# in the main grunt.service unit (p2os, EKFs, supervisor, bt_runner).
# Bagger had a 2026-04-30-vintage bug where several `/nav/` topics
# were specified without the prefix and silently captured nothing.
TOPIC_TEMPLATES = [
    # GPS / RTK / localization (primary suspects under tree coverage)
    '/{prefix}/rtk/fix',
    '/{prefix}/rtk/fix_gated',
    '/{prefix}/rtk/navpvt',
    '/{prefix}/rtk/heading_imu',          # NavPVT-derived yaw observation
                                          # consumed by ekf_global; lets us
                                          # verify which corrections actually
                                          # landed.
    '/{prefix}/localization/status',
    '/{prefix}/odometry/local',
    '/{prefix}/odometry/global',
    '/{prefix}/odometry/gps',
    '/{prefix}/odometry/gps_map',

    # TF
    '/tf',
    '/tf_static',

    # Nav2 plans + costmap — all under /nav/ namespace
    '/{prefix}/nav/plan',                 # planner's published path
    '/{prefix}/nav/received_global_plan', # path RPP actually received
    '/{prefix}/nav/local_plan',           # the controller's local trajectory
    '/{prefix}/nav/global_costmap/costmap',
    '/{prefix}/nav/global_costmap/costmap_updates',
    '/{prefix}/nav/local_costmap/costmap',
    '/{prefix}/nav/local_costmap/costmap_updates',

    # RPP observables — also under /nav/. The carrot and rotation-mode
    # flag are essential for diagnosing controller behavior; without
    # them we can't tell whether the robot is following the carrot
    # correctly or whether it's in a rotate-in-place vs forward-driving
    # mode.
    '/{prefix}/nav/lookahead_point',         # carrot — single point ~L ahead
    '/{prefix}/nav/lookahead_collision_arc', # commanded arc
    '/{prefix}/nav/is_rotating_to_heading',  # std_msgs/Bool — RPP mode flag

    # MPPI observable (only published indoor with MPPI controller; harmless when absent)
    '/{prefix}/nav/optimal_trajectory',

    # Velocity chain
    '/{prefix}/cmd_vel',
    '/{prefix}/cmd_vel_nav',
    '/{prefix}/cmd_vel_nav_raw',
    '/{prefix}/cmd_vel_joy',

    # Recovery + safety state
    '/{prefix}/bt_runner/active_behavior',
    '/{prefix}/bt_runner/armed',
    '/{prefix}/nav/collision_monitor_state',
    '/{prefix}/sonar/cloud',
    '/{prefix}/nav/mode',

    # Mission state
    '/{prefix}/mission_overlay/selected_mission',

    # Action lifecycle (when did Nav2 think it was done? when did it ABORT?)
    # Including _action/goal so the bag self-documents what each action was told
    # to do (waypoint coordinates, escape distances/angles, etc.).
    # All Nav2 action servers live under <prefix>/nav/<action>, NOT at the
    # robot-root namespace — they're spawned by the grunt-nav@<mode>.service
    # unit which pushes its own /nav/ sub-namespace.
    '/{prefix}/nav/follow_gps_waypoints/_action/goal',
    '/{prefix}/nav/follow_gps_waypoints/_action/status',
    '/{prefix}/nav/follow_gps_waypoints/_action/feedback',
    '/{prefix}/nav/navigate_to_pose/_action/goal',
    '/{prefix}/nav/navigate_to_pose/_action/status',
    '/{prefix}/nav/navigate_to_pose/_action/feedback',
    '/{prefix}/nav/backup/_action/goal',
    '/{prefix}/nav/backup/_action/status',
    '/{prefix}/nav/backup/_action/feedback',
    '/{prefix}/nav/spin/_action/goal',
    '/{prefix}/nav/spin/_action/status',
    '/{prefix}/nav/spin/_action/feedback',
    '/{prefix}/nav/drive_on_heading/_action/goal',
    '/{prefix}/nav/drive_on_heading/_action/status',
    '/{prefix}/nav/drive_on_heading/_action/feedback',

    # IMU + joy
    '/{prefix}/bno055/imu',
    '/joy',
]

MISSION_BEHAVIORS = {'run_gps_mission', 'run_pose_mission'}


class DiagnosticBagger(Node):
    def __init__(self):
        super().__init__('diagnostic_bagger')

        self.declare_parameter('prefix', 'grunt1')
        self.declare_parameter('bag_root', os.path.expanduser('~/bag_files/grunt'))

        self.prefix = self.get_parameter('prefix').value
        self.bag_root = Path(self.get_parameter('bag_root').value)
        self.bag_root.mkdir(parents=True, exist_ok=True)

        self.topics = [t.format(prefix=self.prefix) for t in TOPIC_TEMPLATES]

        self.proc = None
        self.current_bag = None
        self.last_behavior = ''

        # active_behavior is transient_local depth 1 in bt_runner so
        # we'll pick up the current state on subscribe.
        latched = QoSProfile(
            depth=1,
            reliability=QoSReliabilityPolicy.RELIABLE,
            durability=QoSDurabilityPolicy.TRANSIENT_LOCAL,
        )
        self.create_subscription(
            String,
            f'/{self.prefix}/bt_runner/active_behavior',
            self._on_behavior, latched)

        self.get_logger().info(
            f'diagnostic_bagger ready: prefix={self.prefix}, '
            f'bag_root={self.bag_root}')

    def _on_behavior(self, msg: String):
        behavior = msg.data
        if behavior == self.last_behavior:
            return
        prev, self.last_behavior = self.last_behavior, behavior

        in_mission = behavior in MISSION_BEHAVIORS
        was_in_mission = prev in MISSION_BEHAVIORS

        if in_mission and not was_in_mission:
            self._start_bag(behavior)
        elif was_in_mission and not in_mission:
            self._stop_bag()

    def _start_bag(self, behavior: str):
        if self.proc is not None:
            self.get_logger().warn('bag already running, skipping start')
            return

        ts = datetime.now().strftime('%Y-%m-%d_%H-%M-%S')
        self.current_bag = self.bag_root / f'{ts}_{behavior}'
        cmd = ['ros2', 'bag', 'record', '-o', str(self.current_bag)] + self.topics

        self.get_logger().info(f'starting bag: {self.current_bag}')
        # start_new_session so signals to our process group don't reach
        # the bag — we control its lifecycle independently.
        self.proc = subprocess.Popen(
            cmd, start_new_session=True,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

    def _stop_bag(self):
        if self.proc is None:
            return
        self.get_logger().info(f'stopping bag: {self.current_bag}')
        try:
            self.proc.send_signal(signal.SIGINT)
            self.proc.wait(timeout=10.0)
        except subprocess.TimeoutExpired:
            self.get_logger().warn(
                'bag did not stop within 10s, sending SIGTERM')
            self.proc.terminate()
            try:
                self.proc.wait(timeout=5.0)
            except subprocess.TimeoutExpired:
                self.proc.kill()
        self.proc = None
        self.current_bag = None

    def destroy_node(self):
        self._stop_bag()
        super().destroy_node()


def main():
    rclpy.init()
    node = DiagnosticBagger()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
