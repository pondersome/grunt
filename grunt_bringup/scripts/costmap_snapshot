#!/usr/bin/env python3
"""Foxglove-independent costmap snapshot.

Subscribes to the local-costmap layers and the L2 obstacle cloud, grabs
one message of each, and renders PNGs — so the L2 ground-filter / costmap
result can be judged without fighting a misbehaving Foxglove session.

Renders:
  costmap_composed.png   — the composed local costmap
  costmap_voxel.png      — voxel_layer alone (the L2 path)
  costmap_obstacle.png   — obstacle_layer alone (sonar)
  l2_obstacle_cloud.png  — points_obstacles, top-down in base_link

Run:
  ros2 run grunt_bringup costmap_snapshot            # writes to cwd
  ros2 run grunt_bringup costmap_snapshot --out /tmp
"""
import sys
import time

import numpy as np

import rclpy
from rclpy.node import Node
from rclpy.qos import (QoSProfile, ReliabilityPolicy, DurabilityPolicy,
                       HistoryPolicy, qos_profile_sensor_data)

from nav_msgs.msg import OccupancyGrid
from sensor_msgs.msg import PointCloud2
from tf2_ros import Buffer, TransformListener, TransformException

import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
from matplotlib.colors import ListedColormap

LATCH = QoSProfile(depth=1, reliability=ReliabilityPolicy.RELIABLE,
                   durability=DurabilityPolicy.TRANSIENT_LOCAL,
                   history=HistoryPolicy.KEEP_LAST)
PREFIX = '/grunt1'
GRIDS = {
    f'{PREFIX}/nav/local_costmap/costmap': 'costmap_composed',
    f'{PREFIX}/nav/local_costmap/voxel_layer': 'costmap_voxel',
    f'{PREFIX}/nav/local_costmap/obstacle_layer': 'costmap_obstacle',
}
CLOUD = f'{PREFIX}/l2/points_obstacles'
# tf2 frame ids must not start with '/'
BASE_FRAME = PREFIX.lstrip('/') + '/base_link'
GRID_CMAP = ListedColormap(['#888888', '#ffffff', '#f0a030', '#c0392b'])


def _transform_matrix(t) -> np.ndarray:
    q = t.transform.rotation
    tr = t.transform.translation
    x, y, z, w = q.x, q.y, q.z, q.w
    s = 0.0 if (x*x+y*y+z*z+w*w) == 0 else 2.0 / (x*x+y*y+z*z+w*w)
    M = np.identity(4)
    M[0, 0] = 1-s*(y*y+z*z); M[0, 1] = s*(x*y-z*w); M[0, 2] = s*(x*z+y*w)
    M[1, 0] = s*(x*y+z*w); M[1, 1] = 1-s*(x*x+z*z); M[1, 2] = s*(y*z-x*w)
    M[2, 0] = s*(x*z-y*w); M[2, 1] = s*(y*z+x*w); M[2, 2] = 1-s*(x*x+y*y)
    M[0, 3], M[1, 3], M[2, 3] = tr.x, tr.y, tr.z
    return M


def render_grid(msg, name, out_dir):
    info = msg.info
    w, h = info.width, info.height
    d = np.array(msg.data, dtype=np.int16).reshape(h, w)
    cat = np.zeros((h, w), dtype=np.int8)
    cat[d == 0] = 1
    cat[(d > 0) & (d < 100)] = 2
    cat[d >= 100] = 3
    ox, oy = info.origin.position.x, info.origin.position.y
    ex = [ox, ox + w * info.resolution, oy, oy + h * info.resolution]
    fig, ax = plt.subplots(figsize=(6, 6))
    ax.imshow(cat, origin='lower', cmap=GRID_CMAP, vmin=0, vmax=3,
              extent=ex, interpolation='nearest')
    lethal = int((d >= 100).sum())
    infl = int(((d > 0) & (d < 100)).sum())
    ax.set_title(f'{name}  (lethal {lethal}, inflated {infl})')
    ax.set_xlabel('x (m, odom)')
    ax.set_ylabel('y (m, odom)')
    fig.tight_layout()
    path = f'{out_dir}/{name}.png'
    fig.savefig(path)
    plt.close(fig)
    return path, lethal, infl


def render_cloud(msg, T, out_dir):
    offs = {f.name: f.offset for f in msg.fields}
    n = msg.width * msg.height
    if n == 0 or not all(k in offs for k in 'xyz'):
        return None
    raw = np.frombuffer(bytes(msg.data), np.uint8).reshape(n, msg.point_step)
    xyz = np.column_stack([raw[:, offs[k]:offs[k]+4].copy().view(
        np.float32).reshape(n) for k in 'xyz']).astype(np.float64)
    xyz = xyz[np.isfinite(xyz).all(axis=1)]
    if T is not None:
        xyz = xyz @ T[:3, :3].T + T[:3, 3]
        frame = 'base_link'
    else:
        frame = msg.header.frame_id + ' (raw — no TF)'
    fig, ax = plt.subplots(figsize=(6, 6))
    sc = ax.scatter(xyz[:, 0], xyz[:, 1], c=xyz[:, 2], s=3,
                    cmap='viridis')
    ax.plot(0, 0, 'k^', markersize=10)
    ax.set_aspect('equal')
    ax.set_title(f'points_obstacles  ({xyz.shape[0]} pts, {frame})')
    ax.set_xlabel('x forward (m)')
    ax.set_ylabel('y left (m)')
    fig.colorbar(sc, ax=ax, label='z (m)')
    fig.tight_layout()
    path = f'{out_dir}/l2_obstacle_cloud.png'
    fig.savefig(path)
    plt.close(fig)
    return path, xyz.shape[0]


def main():
    out_dir = '.'
    argv = sys.argv[1:]
    if '--out' in argv:
        out_dir = argv[argv.index('--out') + 1]

    rclpy.init()
    node = Node('costmap_snapshot')
    tf_buffer = Buffer()
    TransformListener(tf_buffer, node)
    got = {}
    for topic in GRIDS:
        node.create_subscription(OccupancyGrid, topic,
                                 lambda m, t=topic: got.setdefault(t, m),
                                 LATCH)
    node.create_subscription(PointCloud2, CLOUD,
                             lambda m: got.setdefault(CLOUD, m),
                             qos_profile_sensor_data)
    t0 = time.time()
    want = len(GRIDS) + 1
    # spin a minimum window so DDS discovery completes and the TF
    # buffer fills (the latched grids otherwise arrive in <1 s, well
    # before the static-TF tree is assembled).
    while time.time() - t0 < 10.0 and (
            time.time() - t0 < 6.0 or len(got) < want):
        rclpy.spin_once(node, timeout_sec=0.2)

    for topic, name in GRIDS.items():
        if topic in got:
            path, le, inf = render_grid(got[topic], name, out_dir)
            print(f'wrote {path}  (lethal {le}, inflated {inf})')
        else:
            print(f'{topic}: NOT RECEIVED')

    if CLOUD in got:
        T = None
        try:
            tf = tf_buffer.lookup_transform(
                BASE_FRAME, got[CLOUD].header.frame_id, rclpy.time.Time())
            T = _transform_matrix(tf)
        except TransformException as e:
            print(f'cloud TF lookup failed ({e}); rendering raw frame')
        res = render_cloud(got[CLOUD], T, out_dir)
        if res:
            print(f'wrote {res[0]}  ({res[1]} pts)')
    else:
        print(f'{CLOUD}: NOT RECEIVED')

    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()
