#!/usr/bin/env python3
"""
Localization Supervisor Node

Monitors sensor readiness (GPS fix quality, IMU calibration) and gates
the global EKF initialization by calling navsat_transform's /datum service
only when conditions are met.

Supports two heading strategies:
  - NDOF: uses BNO055 magnetometer-fused heading (fast, needs calibration)
  - IMUPlus: computes heading offset from GPS course-over-ground (needs driving)
"""

import json
import math

import rclpy
from rclpy.node import Node
from rclpy.duration import Duration

from sensor_msgs.msg import NavSatFix, Imu
from nav_msgs.msg import Odometry
from std_msgs.msg import String
from std_srvs.srv import Trigger
from geometry_msgs.msg import PoseWithCovarianceStamped
from diagnostic_msgs.msg import DiagnosticArray, DiagnosticStatus, KeyValue
from geographic_msgs.msg import GeoPose, GeoPoint
from geometry_msgs.msg import Quaternion, PoseWithCovarianceStamped

import os
import yaml

from tf_transformations import euler_from_quaternion, quaternion_from_euler

# NavPVT imported with try/except in case ublox_msgs isn't sourced
try:
    from ublox_msgs.msg import NavPVT
    HAS_NAVPVT = True
except ImportError:
    HAS_NAVPVT = False

# robot_localization services
from robot_localization.srv import SetDatum

# NavPVT flags masks
CARRIER_PHASE_MASK = 0xC0
CARRIER_PHASE_NONE = 0x00
CARRIER_PHASE_FLOAT = 0x40
CARRIER_PHASE_FIXED = 0x80
FLAGS_GNSS_FIX_OK = 0x01
FLAGS_DIFF_SOLN = 0x02


def haversine_distance(lat1, lon1, lat2, lon2):
    """Distance in meters between two GPS coordinates."""
    R = 6371000.0
    dlat = math.radians(lat2 - lat1)
    dlon = math.radians(lon2 - lon1)
    a = (math.sin(dlat / 2) ** 2 +
         math.cos(math.radians(lat1)) * math.cos(math.radians(lat2)) *
         math.sin(dlon / 2) ** 2)
    return R * 2 * math.atan2(math.sqrt(a), math.sqrt(1 - a))


def geodetic_bearing(lat1, lon1, lat2, lon2):
    """Bearing in radians from point 1 to point 2 (from north, clockwise)."""
    lat1, lon1 = math.radians(lat1), math.radians(lon1)
    lat2, lon2 = math.radians(lat2), math.radians(lon2)
    dlon = lon2 - lon1
    x = math.sin(dlon) * math.cos(lat2)
    y = (math.cos(lat1) * math.sin(lat2) -
         math.sin(lat1) * math.cos(lat2) * math.cos(dlon))
    return math.atan2(x, y)


def geodetic_to_enu_heading(bearing):
    """Convert geodetic bearing (from north CW) to ENU heading (from east CCW)."""
    return math.pi / 2.0 - bearing


def get_yaw_from_quaternion(q):
    """Extract yaw from a geometry_msgs Quaternion."""
    _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
    return yaw


class LocalizationSupervisor(Node):
    def __init__(self):
        super().__init__('localization_supervisor')

        # Parameters
        # Quality ordering: none=0, gps=1, sbas=2, dgps=3, rtk_float=4, rtk_fixed=5
        self.declare_parameter('gps_quality_threshold', 4)  # rtk_float
        self.declare_parameter('heading_calibration_distance', 3.0)
        self.declare_parameter('mag_calibration_threshold', 2)
        self.declare_parameter('auto_datum', True)
        self.declare_parameter('allow_re_datum', True)
        self.declare_parameter('re_datum_cooldown', 30.0)

        # Default 0.5m matches the cal threshold: assumes RTK is the
        # normal operating mode. Override at launch (e.g.,
        # gps_h_acc_threshold_m:=2.0) when running without RTK
        # corrections so the recorder/relay still see fixes.
        # TODO: refactor to derive accuracy thresholds from quality
        # threshold automatically — see project_behaviors_layer.md
        # backlog ("GPS threshold unification").
        self.declare_parameter('gps_h_acc_threshold_m', 0.5)
        self.declare_parameter('gps_h_acc_cal_threshold_m', 0.5)  # max h_acc for drive cal start/end
        self.declare_parameter('map_frame', 'map')
        # Optional path to per-site site.yaml. If present and contains
        # anchor_lat/anchor_lon, those are used for /datum instead of the
        # robot's current GPS — keeps map-frame origin geographically
        # stable across runs. Empty string = legacy (current fix as datum).
        self.declare_parameter('site_config', '')

        self.gps_quality_threshold = self.get_parameter('gps_quality_threshold').value
        self.heading_cal_distance = self.get_parameter('heading_calibration_distance').value
        self.mag_cal_threshold = self.get_parameter('mag_calibration_threshold').value
        self.auto_datum = self.get_parameter('auto_datum').value
        self.allow_re_datum = self.get_parameter('allow_re_datum').value
        self.re_datum_cooldown = self.get_parameter('re_datum_cooldown').value
        self.gps_h_acc_threshold = self.get_parameter('gps_h_acc_threshold_m').value
        self.gps_h_acc_cal_threshold = self.get_parameter('gps_h_acc_cal_threshold_m').value
        self.map_frame = self.get_parameter('map_frame').value

        # Load per-site GPS anchor (if site.yaml is present and well-formed)
        self.anchor_lat = None
        self.anchor_lon = None
        site_config_path = self.get_parameter('site_config').value
        if site_config_path:
            self._load_site_config(site_config_path)

        # Allow runtime parameter changes via ros2 param set
        self.add_on_set_parameters_callback(self._on_param_change)

        # GPS state
        self.fix_status = -1  # NavSatStatus
        self.carrier_phase = CARRIER_PHASE_NONE
        self.h_acc_mm = 0
        self.gnss_fix_ok = False
        self.last_fix_time = None
        self.current_lat = None
        self.current_lon = None
        self.current_alt = 0.0

        # IMU state
        self.imu_mode = 'unknown'  # 'unknown', 'ndof', 'imuplus'
        self.sys_cal = 0
        self.gyro_cal = 0
        self.accel_cal = 0
        self.mag_cal = 0
        self.calib_msg_count = 0
        self.last_imu_msg = None
        self.last_odom_msg = None

        # Heading state
        self.heading_source = 'none'  # 'none', 'magnetometer', 'drive_calibration'
        self.heading_established = False
        self.heading_enu_rad = None

        # Motion detection
        self.robot_speed = 0.0
        self.robot_vx = 0.0  # signed forward velocity from wheel odometry
        self.min_drive_speed = 0.05  # m/s — must be moving to count toward calibration

        # Drive calibration state (IMUPlus path)
        self.drive_cal_start_lat = None
        self.drive_cal_start_lon = None
        self.drive_cal_start_imu_yaw = None
        self.drive_cal_distance = 0.0
        self.drive_cal_bad_gps_count = 0
        self.drive_cal_bad_gps_limit = 5  # consecutive bad readings before reset
        # Track direction during accumulation to detect/handle backward driving
        # (e.g. backing down a ramp on launch). All non-trivial samples must
        # have the same sign or accumulation resets.
        self.drive_cal_direction = 0  # 0 = unknown, +1 = forward, -1 = backward

        # Datum state
        self.datum_set = False
        self.datum_set_time = None
        self.datum_gps_quality = 'none'
        self.datum_pending = False

        # Environment
        self.environment = 'unknown'
        self.gps_timeout_sec = 30.0

        # Subscribers
        self.create_subscription(NavSatFix, 'rtk/fix', self._fix_cb, 10)
        if HAS_NAVPVT:
            self.create_subscription(NavPVT, 'rtk/navpvt', self._navpvt_cb, 10)
        self.create_subscription(Imu, 'bno055/imu', self._imu_cb, 10)
        self.create_subscription(String, 'bno055/calib_status', self._calib_cb, 10)
        self.create_subscription(Odometry, 'odometry/local', self._odom_cb, 10)

        # Publishers
        self.status_pub = self.create_publisher(String, 'localization/status', 10)
        self.diag_pub = self.create_publisher(DiagnosticArray, 'diagnostics', 10)
        # Gated GPS fix: forwards rtk/fix to navsat_transform only after the
        # datum has been set. Uses default RELIABLE QoS to match
        # navsat_transform's subscription QoS.
        self.gated_fix_pub = self.create_publisher(NavSatFix, 'rtk/fix_gated', 10)

        # GPS odometry relay: subscribes to navsat_transform's /odometry/gps
        # (published in odom frame) and republishes with frame_id changed to
        # map frame. This breaks a positive feedback loop in the global EKF
        # where it uses its OWN map→odom TF to transform GPS measurements,
        # causing a constant innovation that compounds linearly.
        # By relaying in the map frame, no TF lookup is needed.
        self.create_subscription(Odometry, 'odometry/gps', self._gps_odom_relay_cb, 10)
        self.gps_odom_map_pub = self.create_publisher(Odometry, 'odometry/gps_map', 10)
        # Used to reset the global EKF state during a calibration reset.
        # Remapped from the EKF's default 'set_pose' to keep it isolated from
        # the local EKF (which has its own remap to 'set_pose_local').
        self.global_set_pose_pub = self.create_publisher(
            PoseWithCovarianceStamped, 'set_pose', 10)

        # Service client
        self.datum_client = self.create_client(SetDatum, 'datum')

        # Service server: reset_calibration
        # Clears all heading/datum state so the supervisor restarts the
        # calibration sequence as if just launched. Used to recover from
        # a bad calibration without restarting the entire stack.
        self.reset_srv = self.create_service(
            Trigger, '~/reset_calibration', self._reset_calibration_srv)

        # 1 Hz evaluation timer
        self.create_timer(1.0, self._periodic_evaluate)

        self.get_logger().info('Localization supervisor started')

    # ── Callbacks ──

    def _fix_cb(self, msg: NavSatFix):
        self.fix_status = msg.status.status
        self.current_lat = msg.latitude
        self.current_lon = msg.longitude
        self.current_alt = msg.altitude
        self.last_fix_time = self.get_clock().now()

        # Forward to navsat_transform ONLY after the supervisor has called
        # /datum with calibrated heading. Three reasons to gate this strictly:
        #
        # 1. navsat_transform's wait_for_datum mode does not gate input
        #    processing — it tries to UTM-convert every fix on the input
        #    side, fails for any fix not in its default zone (31), and
        #    spams an error per fix at GPS rate.
        #
        # 2. setUTMZone (the obvious workaround for #1) has a side effect
        #    of setting use_manual_datum_=false, which silently disables
        #    wait_for_datum and triggers an auto-datum from the next fix.
        #    The auto-datum uses garbage heading and corrupts the EKF.
        #
        # 3. By starving navsat_transform of fixes until /datum has been
        #    called manually, we avoid both problems entirely. After /datum,
        #    the zone is set correctly and use_manual_datum_ stays true.
        #
        # The supervisor uses its own current_lat/lon (set above) for the
        # drive calibration logic, so this gating does not affect calibration.
        if not self.datum_set:
            return

        # Filter out garbage fixes that may sneak through after datum is set.
        if not self._gps_usable() or (msg.latitude == 0.0 and msg.longitude == 0.0):
            return

        self.gated_fix_pub.publish(msg)

    # ── Parameter Callback ──

    def _on_param_change(self, params):
        from rcl_interfaces.msg import SetParametersResult
        param_map = {
            'gps_quality_threshold': 'gps_quality_threshold',
            'heading_calibration_distance': 'heading_cal_distance',
            'mag_calibration_threshold': 'mag_cal_threshold',
            'auto_datum': 'auto_datum',
            'allow_re_datum': 'allow_re_datum',
            're_datum_cooldown': 're_datum_cooldown',
            'gps_h_acc_threshold_m': 'gps_h_acc_threshold',
            'gps_h_acc_cal_threshold_m': 'gps_h_acc_cal_threshold',
        }
        for param in params:
            if param.name in param_map:
                attr = param_map[param.name]
                old_val = getattr(self, attr)
                setattr(self, attr, param.value)
                self.get_logger().info(f'Parameter {param.name} changed: {old_val} → {param.value}')
        return SetParametersResult(successful=True)

    # ── Sensor Callbacks ──

    def _navpvt_cb(self, msg):
        self.gnss_fix_ok = bool(msg.flags & FLAGS_GNSS_FIX_OK)
        self.carrier_phase = msg.flags & CARRIER_PHASE_MASK
        self.h_acc_mm = msg.h_acc

    def _imu_cb(self, msg: Imu):
        self.last_imu_msg = msg

    def _calib_cb(self, msg: String):
        try:
            data = json.loads(msg.data)
            self.sys_cal = data.get('sys', 0)
            self.gyro_cal = data.get('gyro', 0)
            self.accel_cal = data.get('accel', 0)
            self.mag_cal = data.get('mag', 0)
            self.calib_msg_count += 1
        except (json.JSONDecodeError, KeyError):
            pass

        self._detect_imu_mode()

    def _gps_odom_relay_cb(self, msg: Odometry):
        """Relay GPS odometry with frame_id changed to map frame.

        navsat_transform publishes /odometry/gps with frame_id=odom. The
        global EKF (world_frame=map) must transform this via its own
        map→odom TF, creating a self-referential feedback loop that
        causes linear divergence. By republishing with frame_id=map,
        the EKF accepts the measurement directly — no TF lookup needed.

        This is valid because navsat_transform's datum defines the map
        origin: GPS positions relative to the datum ARE map positions.
        """
        relay = Odometry()
        relay.header = msg.header
        relay.header.frame_id = self.map_frame  # grunt1/map instead of grunt1/odom
        relay.child_frame_id = msg.child_frame_id
        relay.pose = msg.pose
        relay.twist = msg.twist
        self.gps_odom_map_pub.publish(relay)

    def _odom_cb(self, msg: Odometry):
        speed = math.sqrt(msg.twist.twist.linear.x ** 2 +
                          msg.twist.twist.linear.y ** 2)
        self.robot_speed = speed
        self.robot_vx = msg.twist.twist.linear.x  # signed forward velocity
        self.last_odom_msg = msg  # stored for _sync_global_to_local

    # ── IMU Mode Detection ──

    def _detect_imu_mode(self):
        if self.imu_mode != 'unknown':
            return

        if self.mag_cal > 0:
            self.imu_mode = 'ndof'
            self.get_logger().info('IMU mode detected: NDOF (magnetometer active)')
        elif self.calib_msg_count >= 3 and self.mag_cal == 0:
            self.imu_mode = 'imuplus'
            self.get_logger().info(
                '\033[32mIMU mode detected: IMUPlus (no magnetometer). '
                f'Drive {self.heading_cal_distance:.1f}m with good GPS to establish heading.\033[0m')

    # ── Heading Evaluation ──

    def _check_ndof_heading(self):
        """Check if NDOF heading is ready."""
        if self.mag_cal >= self.mag_cal_threshold and self.sys_cal >= 1:
            if self.last_imu_msg is not None:
                yaw = get_yaw_from_quaternion(self.last_imu_msg.orientation)
                self.heading_enu_rad = yaw
                self.heading_source = 'magnetometer'
                self.heading_established = True
                return True
        return False

    def _update_drive_calibration(self):
        """Accumulate GPS displacement for IMUPlus heading calibration.

        Requires the same GPS quality threshold as datum setting to ensure
        the bearing calculation is based on accurate positions.
        """
        # Skip if heading established and re-calibration not allowed or cooldown active
        if self.heading_established:
            if not self.allow_re_datum or not self._cooldown_elapsed():
                return

        # During accumulation: only need usable GPS (sane accuracy), not full quality
        # Full quality is required at completion for accurate bearing calculation
        if not self._gps_usable() or self.current_lat is None:
            self.drive_cal_bad_gps_count += 1
            if self.drive_cal_bad_gps_count >= self.drive_cal_bad_gps_limit:
                if self.drive_cal_start_lat is not None:
                    self.get_logger().warn(
                        f'Drive cal: RESET after {self.drive_cal_bad_gps_count} bad readings '
                        f'(fix_status={self.fix_status}, h_acc_mm={self.h_acc_mm}, '
                        f'had {self.drive_cal_distance:.2f}m accumulated)')
                    self.drive_cal_start_lat = None
                    self.drive_cal_distance = 0.0
            return
        self.drive_cal_bad_gps_count = 0  # reset counter on good reading

        # Need IMU data
        if self.last_imu_msg is None:
            return

        current_imu_yaw = get_yaw_from_quaternion(self.last_imu_msg.orientation)

        # Robot must be actually moving (wheel odometry confirms motion)
        # This prevents GPS convergence from being mistaken for driving
        if self.robot_speed < self.min_drive_speed:
            return

        # Determine current direction from signed forward velocity
        sample_direction = 1 if self.robot_vx > 0 else -1

        if self.drive_cal_start_lat is None:
            # Only record start at full GPS quality AND tight horizontal accuracy
            h_acc_m = self.h_acc_mm / 1000.0
            if not self._gps_quality_met() or h_acc_m > self.gps_h_acc_cal_threshold:
                return
            self.drive_cal_start_lat = self.current_lat
            self.drive_cal_start_lon = self.current_lon
            self.drive_cal_start_imu_yaw = current_imu_yaw
            self.drive_cal_distance = 0.0
            self.drive_cal_direction = sample_direction
            dir_str = 'forward' if sample_direction > 0 else 'backward'
            self.get_logger().info(
                f'Drive cal: start recorded at ({self.current_lat:.6f}, {self.current_lon:.6f}) '
                f'GPS={self._gps_fix_level()}, direction={dir_str}')
            return

        # Reject mid-drive direction changes — calibration must be consistent
        if sample_direction != self.drive_cal_direction:
            self.get_logger().warn(
                f'Drive cal: direction reversed mid-calibration '
                f'({"forward" if self.drive_cal_direction > 0 else "backward"} → '
                f'{"forward" if sample_direction > 0 else "backward"}), '
                f'resetting accumulator (had {self.drive_cal_distance:.2f}m)')
            self.drive_cal_start_lat = None
            self.drive_cal_distance = 0.0
            self.drive_cal_direction = 0
            return

        # Compute distance from start
        dist = haversine_distance(
            self.drive_cal_start_lat, self.drive_cal_start_lon,
            self.current_lat, self.current_lon)
        self.drive_cal_distance = dist
        self.get_logger().debug(
            f'Drive cal: dist={dist:.2f}m from ({self.drive_cal_start_lat:.6f},{self.drive_cal_start_lon:.6f}) '
            f'to ({self.current_lat:.6f},{self.current_lon:.6f})')

        if dist >= self.heading_cal_distance:
            # Require full GPS quality AND tight accuracy for final bearing
            h_acc_m = self.h_acc_mm / 1000.0
            if not self._gps_quality_met() or h_acc_m > self.gps_h_acc_cal_threshold:
                return

            # Compute GPS bearing from start to current position.
            # If we drove backward, the bearing points 180° away from the
            # robot's actual heading — flip it.
            bearing = geodetic_bearing(
                self.drive_cal_start_lat, self.drive_cal_start_lon,
                self.current_lat, self.current_lon)
            gps_enu_heading = geodetic_to_enu_heading(bearing)
            if self.drive_cal_direction < 0:
                gps_enu_heading = (gps_enu_heading + math.pi) % (2 * math.pi)
                if gps_enu_heading > math.pi:
                    gps_enu_heading -= 2 * math.pi

            # Compute offset: GPS heading - IMU yaw
            offset = gps_enu_heading - current_imu_yaw

            recal = self.heading_established
            self.heading_enu_rad = current_imu_yaw + offset
            self.heading_source = 'drive_calibration'
            self.heading_established = True

            # Capture direction for log message before resetting accumulator
            dir_label = 'backward (flipped)' if self.drive_cal_direction < 0 else 'forward'

            # Reset accumulator for potential future re-calibration
            self.drive_cal_start_lat = None
            self.drive_cal_distance = 0.0
            self.drive_cal_direction = 0

            self.get_logger().info(
                f'{"Re-calibrated" if recal else "Drive calibration complete"}: '
                f'GPS-derived ENU heading={math.degrees(gps_enu_heading):.1f}° '
                f'(compass bearing={math.degrees(math.pi/2.0 - gps_enu_heading):.1f}°), '
                f'IMU yaw={math.degrees(current_imu_yaw):.1f}°, '
                f'offset={math.degrees(offset):.1f}°, '
                f'distance={dist:.2f}m, direction={dir_label}, '
                f'GPS={self._gps_fix_level()}')

    # ── GPS Quality ──

    def _gps_usable(self) -> bool:
        """Check if GPS has a real fix with sane accuracy (not indoor garbage)."""
        if self.fix_status < 0:
            return False
        h_acc_m = self.h_acc_mm / 1000.0
        return h_acc_m < self.gps_h_acc_threshold

    def _gps_fix_level(self) -> str:
        if self.fix_status < 0 or not self._gps_usable():
            return 'none'
        if self.carrier_phase == CARRIER_PHASE_FIXED:
            return 'rtk_fixed'
        if self.carrier_phase == CARRIER_PHASE_FLOAT:
            return 'rtk_float'
        if self.fix_status >= 2:
            return 'dgps'
        if self.fix_status >= 1:
            return 'sbas'
        if self.fix_status >= 0:
            return 'gps'
        return 'none'

    def _gps_quality_met(self) -> bool:
        """Check if GPS quality meets the threshold using the unified fix level.

        The quality ordering unifies NavSatFix status and NavPVT carrier phase:
          none=0, gps=1, sbas=2, dgps=3, rtk_float=4, rtk_fixed=5
        The threshold parameter maps to this ordering.
        """
        quality_order = {'none': 0, 'gps': 1, 'sbas': 2, 'dgps': 3, 'rtk_float': 4, 'rtk_fixed': 5}
        current = quality_order.get(self._gps_fix_level(), 0)
        return current >= self.gps_quality_threshold

    def _gps_quality_improved(self) -> bool:
        """Check if GPS quality improved since last datum."""
        quality_order = {'none': 0, 'gps': 1, 'sbas': 2, 'dgps': 3, 'rtk_float': 4, 'rtk_fixed': 5}
        current = quality_order.get(self._gps_fix_level(), 0)
        previous = quality_order.get(self.datum_gps_quality, 0)
        return current > previous

    # ── Calibration Reset ──

    def _reset_calibration_srv(self, request, response):
        """Service handler: clear all heading/datum state and restart sequence.

        Use case: bad calibration (e.g. wrong direction during a backward
        ramp descent) needs to be redone without losing GPS lock by
        restarting the whole stack.

        Side effects:
          - Clears supervisor heading and drive_cal state
          - Resets datum_set flag (next /datum call will re-establish it)
          - Publishes a zero pose to the global EKF set_pose to clear its
            accumulated state, so the new datum starts from a clean slate
        """
        had_heading = self.heading_established
        had_datum = self.datum_set

        # Clear heading state
        self.heading_source = 'none'
        self.heading_established = False
        self.heading_enu_rad = None

        # Clear drive cal accumulator
        self.drive_cal_start_lat = None
        self.drive_cal_start_lon = None
        self.drive_cal_start_imu_yaw = None
        self.drive_cal_distance = 0.0
        self.drive_cal_bad_gps_count = 0
        self.drive_cal_direction = 0

        # Clear datum state. The next periodic_evaluate cycle will go
        # through the normal sequence: wait for heading, then call /datum.
        # navsat_transform handles repeated /datum calls correctly.
        self.datum_set = False
        self.datum_set_time = None
        self.datum_gps_quality = 'none'
        self.datum_pending = False

        # Reset the global EKF's accumulated state. Without this, the EKF
        # would still believe its last (x, y) position when the new datum
        # arrives, causing a large initial discontinuity.
        self._reset_global_ekf()

        self.get_logger().warn(
            f'Calibration RESET via service '
            f'(had_heading={had_heading}, had_datum={had_datum}). '
            f'Awaiting new heading calibration.')

        response.success = True
        response.message = (
            f'Cleared heading and datum state. '
            f'Will re-calibrate when GPS reaches quality threshold and '
            f'robot drives {self.heading_cal_distance:.1f}m straight.')
        return response

    # ── Datum Management ──

    def _load_site_config(self, path):
        """Read site.yaml and pull anchor_lat/anchor_lon if present.

        Missing or malformed file → log warning and fall back to legacy
        behavior (use first GPS fix as datum). Operator can survey the
        anchor at a known feature once and reuse across runs.
        """
        if not os.path.exists(path):
            self.get_logger().warn(
                f'site_config={path} not found; '
                f'falling back to first GPS fix as datum')
            return
        try:
            with open(path, 'r') as f:
                cfg = yaml.safe_load(f) or {}
            lat = cfg.get('anchor_lat')
            lon = cfg.get('anchor_lon')
            if lat is None or lon is None:
                self.get_logger().warn(
                    f'site_config={path} missing anchor_lat/anchor_lon; '
                    f'falling back to first GPS fix as datum')
                return
            self.anchor_lat = float(lat)
            self.anchor_lon = float(lon)
            self.get_logger().info(
                f'site anchor loaded from {path}: '
                f'lat={self.anchor_lat:.9f}, lon={self.anchor_lon:.9f}')
        except Exception as e:
            self.get_logger().error(
                f'failed to parse site_config={path}: {e}; '
                f'falling back to first GPS fix as datum')

    def _try_set_datum(self):
        if self.datum_pending:
            return
        if self.current_lat is None or self.heading_enu_rad is None:
            return
        if not self.datum_client.service_is_ready():
            self.get_logger().warn('Datum service not available, waiting...')
            return

        # Use site anchor if configured; otherwise use current GPS fix.
        # The anchor gives a stable map-frame origin across runs (any saved
        # static-map content references the same physical location every
        # session). Without anchor, datum floats with cal location.
        if self.anchor_lat is not None and self.anchor_lon is not None:
            datum_lat, datum_lon = self.anchor_lat, self.anchor_lon
            datum_source = f'site anchor ({self.anchor_lat:.6f}, {self.anchor_lon:.6f})'
        else:
            datum_lat, datum_lon = self.current_lat, self.current_lon
            datum_source = 'current GPS fix (no site anchor configured)'

        # Build GeoPose
        request = SetDatum.Request()
        request.geo_pose.position.latitude = datum_lat
        request.geo_pose.position.longitude = datum_lon
        request.geo_pose.position.altitude = self.current_alt

        quat = quaternion_from_euler(0.0, 0.0, self.heading_enu_rad)
        request.geo_pose.orientation.x = quat[0]
        request.geo_pose.orientation.y = quat[1]
        request.geo_pose.orientation.z = quat[2]
        request.geo_pose.orientation.w = quat[3]

        fix_level = self._gps_fix_level()
        imu_yaw_now = get_yaw_from_quaternion(self.last_imu_msg.orientation) if self.last_imu_msg else None
        self.get_logger().info(
            f'Setting datum: lat={datum_lat:.6f}, lon={datum_lon:.6f}, alt={self.current_alt:.2f} '
            f'[source: {datum_source}], '
            f'heading={math.degrees(self.heading_enu_rad):.1f}° ENU ({self.heading_enu_rad:.4f} rad), '
            f'quat=[{quat[0]:.4f}, {quat[1]:.4f}, {quat[2]:.4f}, {quat[3]:.4f}], '
            f'GPS={fix_level}, h_acc={self.h_acc_mm/1000:.3f}m, '
            f'heading_source={self.heading_source}, '
            f'imu_yaw_now={math.degrees(imu_yaw_now):.1f}° ({imu_yaw_now:.4f} rad)' if imu_yaw_now is not None else '')
        self.get_logger().info(
            'navsat_transform configured with magnetic_declination=0, '
            'yaw_offset=0, use_local_cartesian=true — heading passes '
            'through unrotated; map frame is true ENU at the datum.')

        self.datum_pending = True
        future = self.datum_client.call_async(request)
        future.add_done_callback(
            lambda f: self._datum_response(f, fix_level))

    def _datum_response(self, future, fix_level):
        self.datum_pending = False
        try:
            future.result()

            # CRITICAL: Before opening the GPS gate (datum_set=True), sync
            # the global EKF state to match the local EKF state. This ensures
            # map→odom ≈ identity, so the first GPS measurement (near 0 in
            # odom frame, since the datum IS the current GPS position) maps
            # to near the state (also near 0 in map ≈ odom). Without this,
            # the 3m dead-reckoning drift from the calibration drive creates
            # a constant innovation that feeds a positive feedback loop in
            # the EKF's self-referential odom→map transformation.
            self._sync_global_to_local()

            self.datum_set = True
            self.datum_set_time = self.get_clock().now()
            self.datum_gps_quality = fix_level
            self.get_logger().info(f'Datum set successfully (GPS: {fix_level})')
        except Exception as e:
            self.get_logger().error(f'Datum service call failed: {e}')

    def _sync_global_to_local(self):
        """Seed the global EKF's state at /datum time.

        Position: copy from local EKF. The local EKF has been
        integrating wheel odometry since boot; using its position keeps
        the first GPS observation's innovation small (map ≈ odom in
        position at the datum point), preventing a feedback loop that
        would otherwise shove a constant offset back into map→odom on
        every new GPS update.

        Orientation: use the cal-computed `heading_enu_rad`, NOT the
        local EKF's orientation. Both EKFs consume BNO055 vyaw (gyro
        rate) only — neither absorbs the chip's absolute yaw — so the
        local EKF's yaw is whatever the BNO055 has integrated to since
        chip cold-boot, in a frame with no relation to ENU truth. The
        cal computes the static rotation between BNO055-frame and ENU
        and stores it in `heading_enu_rad`; pushing that into the
        global EKF's yaw state is what closes the loop. Without this,
        the EKF starts ~tens-of-degrees off and NavPVT yaw fusion's
        Mahalanobis gate can reject corrections wide enough to dig out
        of the hole, producing the wandering we saw on 2026-04-29.
        """
        if self.last_odom_msg is None:
            self.get_logger().warn('No local odom available for global EKF sync')
            return
        if self.heading_enu_rad is None:
            self.get_logger().warn(
                'No cal-computed heading available for global EKF sync; '
                'falling back to local-EKF orientation (will likely be '
                'wrong in ENU). This indicates _sync_global_to_local was '
                'called outside the post-cal /datum flow.')

        msg = PoseWithCovarianceStamped()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = self.map_frame

        # Position: copy from local EKF (low-innovation seeding)
        msg.pose.pose.position = self.last_odom_msg.pose.pose.position

        # Orientation: cal-computed ENU yaw (or fall back to local
        # EKF's orientation if heading is somehow unset)
        if self.heading_enu_rad is not None:
            quat = quaternion_from_euler(0.0, 0.0, self.heading_enu_rad)
            msg.pose.pose.orientation.x = quat[0]
            msg.pose.pose.orientation.y = quat[1]
            msg.pose.pose.orientation.z = quat[2]
            msg.pose.pose.orientation.w = quat[3]
        else:
            msg.pose.pose.orientation = self.last_odom_msg.pose.pose.orientation

        # Loose covariance so subsequent GPS measurements can pull the state
        cov = [0.0] * 36
        cov[0] = 1.0    # x
        cov[7] = 1.0    # y
        cov[14] = 1.0   # z
        cov[21] = 0.1   # roll
        cov[28] = 0.1   # pitch
        cov[35] = 1.0   # yaw
        msg.pose.covariance = cov

        self.global_set_pose_pub.publish(msg)
        lp = self.last_odom_msg.pose.pose.position
        heading_str = (
            f'{math.degrees(self.heading_enu_rad):.1f}° ENU'
            if self.heading_enu_rad is not None else 'fallback (local-EKF)')
        self.get_logger().info(
            f'Global EKF synced: pos=({lp.x:.3f}, {lp.y:.3f}) from local, '
            f'yaw={heading_str}')

    def _reset_global_ekf(self):
        """Reset the global EKF to a clean state via set_pose.

        Used both:
          - During calibration reset (no heading yet) — publishes a zero
            pose with identity orientation and loose covariance, so the
            EKF accepts the new datum cleanly when it arrives
          - After a re-datum on heading change (future use) — would
            publish the current heading

        Currently this only handles the reset case. The post-datum repose
        path is left as a placeholder for the planned automatic
        recalibration feature.
        """
        msg = PoseWithCovarianceStamped()
        msg.header.stamp = self.get_clock().now().to_msg()
        msg.header.frame_id = self.map_frame

        # Position at origin
        msg.pose.pose.position.x = 0.0
        msg.pose.pose.position.y = 0.0
        msg.pose.pose.position.z = 0.0

        # Identity orientation (no calibrated heading yet during reset)
        msg.pose.pose.orientation.x = 0.0
        msg.pose.pose.orientation.y = 0.0
        msg.pose.pose.orientation.z = 0.0
        msg.pose.pose.orientation.w = 1.0

        # Loose covariance so the next datum/measurement can pull the state
        cov = [0.0] * 36
        for i in range(6):
            cov[i * 6 + i] = 1.0
        msg.pose.covariance = cov

        self.global_set_pose_pub.publish(msg)
        self.get_logger().info('Global EKF state reset (zero pose, loose covariance)')

    def _cooldown_elapsed(self) -> bool:
        if self.datum_set_time is None:
            return True
        elapsed = (self.get_clock().now() - self.datum_set_time).nanoseconds / 1e9
        return elapsed >= self.re_datum_cooldown

    # ── Periodic Evaluation ──

    def _periodic_evaluate(self):
        # Update environment estimate based on GPS usability, not just message receipt
        if self.last_fix_time is not None:
            age = (self.get_clock().now() - self.last_fix_time).nanoseconds / 1e9
            if age >= self.gps_timeout_sec:
                self.environment = 'indoor'
            elif self._gps_usable():
                self.environment = 'outdoor'
            else:
                # Receiving GPS messages but accuracy is garbage (e.g., indoors)
                self.environment = 'indoor'
        elif self.environment == 'unknown' and self.calib_msg_count > 0:
            self.environment = 'indoor'  # IMU active but no GPS ever received

        # Evaluate heading
        if not self.heading_established:
            if self.imu_mode == 'ndof':
                self._check_ndof_heading()
            elif self.imu_mode == 'imuplus':
                self._update_drive_calibration()
        elif self.imu_mode == 'ndof' and self.last_imu_msg is not None:
            # Continuously update NDOF heading (it tracks magnetic north)
            self.heading_enu_rad = get_yaw_from_quaternion(self.last_imu_msg.orientation)

        # Evaluate datum
        if self.auto_datum and self.heading_established and self._gps_quality_met():
            if not self.datum_set:
                self._try_set_datum()
            elif (self.allow_re_datum and self._gps_quality_improved()
                  and self._cooldown_elapsed()):
                self.get_logger().info(
                    f'GPS quality improved ({self.datum_gps_quality} → {self._gps_fix_level()}), '
                    'setting new datum')
                self._try_set_datum()

        # Publish status
        self._publish_status()

    # ── Status Publishing ──

    def _publish_status(self):
        fix_level = self._gps_fix_level()
        h_acc_m = self.h_acc_mm / 1000.0 if self.h_acc_mm > 0 else None
        heading_deg = math.degrees(self.heading_enu_rad) if self.heading_enu_rad is not None else None

        nav_ready = self.datum_set and self._gps_quality_met()

        # Drive cal info for status
        drive_cal_info = None
        if self.imu_mode == 'imuplus' and not self.heading_established:
            remaining = max(0.0, self.heading_cal_distance - self.drive_cal_distance)
            if self.drive_cal_direction != 0:
                dir_label = 'forward' if self.drive_cal_direction > 0 else 'backward'
                drive_cal_info = f'drive {remaining:.1f}m {dir_label} to calibrate heading'
            else:
                drive_cal_info = f'drive {remaining:.1f}m to calibrate heading'

        # JSON status
        status = {
            'gps_fix': fix_level,
            'gps_h_acc_m': round(h_acc_m, 3) if h_acc_m else None,
            'imu_mode': self.imu_mode,
            'imu_cal': {
                'sys': self.sys_cal,
                'gyro': self.gyro_cal,
                'accel': self.accel_cal,
                'mag': self.mag_cal,
            },
            'heading_source': self.heading_source,
            'heading_established': self.heading_established,
            'heading_deg': round(heading_deg, 1) if heading_deg is not None else None,
            'datum_set': self.datum_set,
            'datum_gps_quality': self.datum_gps_quality,
            'environment': self.environment,
            'nav_ready': nav_ready,
        }
        if drive_cal_info:
            status['drive_cal'] = drive_cal_info

        msg = String()
        msg.data = json.dumps(status)
        self.status_pub.publish(msg)

        # Diagnostics
        diag = DiagnosticArray()
        diag.header.stamp = self.get_clock().now().to_msg()

        ds = DiagnosticStatus()
        ds.name = 'localization_supervisor'
        ds.hardware_id = 'grunt_localization'

        if nav_ready:
            ds.level = DiagnosticStatus.OK
            ds.message = f'Navigation ready (GPS: {fix_level})'
        elif self.datum_set:
            ds.level = DiagnosticStatus.WARN
            ds.message = f'Datum set but GPS degraded ({fix_level})'
        elif self.heading_established:
            ds.level = DiagnosticStatus.WARN
            ds.message = f'Heading ready, waiting for GPS ({fix_level})'
        else:
            ds.level = DiagnosticStatus.ERROR
            ds.message = f'Not ready: {drive_cal_info or "waiting for heading"}'

        for key, val in status.items():
            if key == 'imu_cal':
                ds.values.append(KeyValue(key='imu_cal', value=json.dumps(val)))
            else:
                ds.values.append(KeyValue(key=key, value=str(val)))

        diag.status.append(ds)
        self.diag_pub.publish(diag)


def main(args=None):
    rclpy.init(args=args)
    node = LocalizationSupervisor()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()
