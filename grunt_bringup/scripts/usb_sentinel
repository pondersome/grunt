#!/usr/bin/env bash
# USB topology sentinel — watches the kernel log for USB connect/
# disconnect events and snapshots bus topology + udev symlinks each
# time one fires. Writes append-only to a persistent log file with
# `sync` after each event so the record survives a hard reboot.
#
# Why: Grunt has had repeating "robot stops responding + network feels
# offline" faults since the chassis-B transplant. The 2026-05-28
# composite_drive bag captured one: kernel log showed two USB drops on
# bus 3 within a minute — joystick dongle at 22:09:18 (re-enumerated,
# joy_controller stuck on dead fd) and ARCOS FTDI at 22:10:18
# (re-enumerated as ttyUSB3, p2os_driver stuck on /dev/grunt_p3at
# pointing at ttyUSB0). Same shape as
# project_chassis_vibration_electronics. Cleanly diagnosable from
# `journalctl -b -N -k` after the fact, but only if you know to look
# and the boot history hasn't rotated out — this sentinel keeps a
# dedicated, persistent timeline so the next event is one `tail` away.
#
# Pure bash; no ROS dependency. Designed to run from a systemd user
# unit (no root) — needs only journal-read permission, which the user
# has by default on Ubuntu when in the `systemd-journal` group (the
# `karim` user already is via the `adm` group).
#
# Output: $LOG_FILE (default ~/bag_files/grunt/_usb_sentinel.log).
# Append-only, syncs after each event. Operator can tail/grep at any
# time; the file is plain text.
#
# Stop with Ctrl-C / SIGTERM — the journalctl follower exits cleanly.

set -u
set -o pipefail

LOG_DIR="${LOG_DIR:-$HOME/bag_files/grunt}"
LOG_FILE="${LOG_FILE:-${LOG_DIR}/_usb_sentinel.log}"
# NVMe device for SMART power-loss counter sampling. Auto-detect if
# present; if absent the SMART block in each snapshot is just skipped.
NVME_DEV="${NVME_DEV:-/dev/nvme0n1}"

mkdir -p "${LOG_DIR}"

# SMART counter capture: the NVMe SSD's `unsafe_shutdowns` attribute
# is the single best signal for "the NUC lost power without OS
# cooperation" — it increments only on hard power-off, not on clean
# reboot. `power_cycles` is the total (clean + unsafe). Sampling on
# every USB event lets us correlate "the USB just dropped" with
# "did the NUC also briefly lose power" — the central question of
# the chassis-B brown-out hypothesis (project_chassis_b_usb_drops).
#
# Requires `nvme-cli` (apt install nvme-cli) and root for the
# /dev/nvmeXn1 device. We try non-interactive sudo; if that fails,
# we emit a one-line note instead of the counters. To enable
# unattended capture, add to /etc/sudoers.d/grunt-usb-sentinel:
#
#   karim ALL=(root) NOPASSWD: /usr/sbin/nvme smart-log /dev/nvme0n1
#
# (without the trailing newline / comment characters; visudo -f to
# verify syntax.)
emit_smart_counters() {
  if [ ! -e "${NVME_DEV}" ]; then
    echo "(no ${NVME_DEV}; SMART counters skipped)"
    return
  fi
  if ! command -v nvme >/dev/null 2>&1; then
    echo "(nvme-cli not installed; apt install nvme-cli to enable)"
    return
  fi
  local out
  if out=$(sudo -n nvme smart-log "${NVME_DEV}" 2>/dev/null); then
    echo "${out}" | grep -E "^(unsafe_shutdowns|power_cycles|power_on_hours|controller_busy_time)" \
      || echo "(nvme smart-log produced no expected fields)"
  else
    echo "(sudo -n nvme smart-log failed; add NOPASSWD sudoers entry — see script comments)"
  fi
}

# Match these kernel-log substrings. Deliberately broad — every USB
# topology change is interesting; filtering is cheaper than missing
# events.
MATCH='usb [0-9]+-[0-9.]+|ftdi_sio|cdc_acm|hid-generic|input: |xhci_hcd.*ERROR|USB disconnect|new.*device'

emit_snapshot() {
  local trigger="$1"
  {
    echo "===================================================================="
    echo "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)  TRIGGER"
    echo "${trigger}"
    echo
    echo "--- lsusb -t ---"
    lsusb -t 2>&1
    echo
    echo "--- /dev/serial/by-id ---"
    ls -la /dev/serial/by-id 2>/dev/null || echo "(none)"
    echo
    echo "--- /dev/input ---"
    ls -la /dev/input/js* /dev/input/event* 2>/dev/null || echo "(none)"
    echo
    echo "--- /dev/grunt_* (udev-rule symlinks) ---"
    ls -la /dev/grunt_* 2>/dev/null || echo "(none)"
    echo
    echo "--- NVMe SMART counters (unsafe_shutdowns = NUC hard-power-off count) ---"
    emit_smart_counters
    echo
  } >> "${LOG_FILE}"
  # Force the kernel page cache out to disk so the record survives a
  # hard reboot. `sync` is global — a few-event-per-minute rate is
  # nowhere near costly.
  sync
}

# Header on each daemon start so we can correlate runs across reboots.
{
  echo "===================================================================="
  echo "$(date -u +%Y-%m-%dT%H:%M:%S.%3NZ)  SENTINEL START"
  echo "host=$(hostname) pid=$$ uid=${UID}"
  echo
  echo "--- initial lsusb -t ---"
  lsusb -t 2>&1
  echo
  echo "--- initial /dev/serial/by-id ---"
  ls -la /dev/serial/by-id 2>/dev/null || echo "(none)"
  echo
  echo "--- initial NVMe SMART counters ---"
  emit_smart_counters
  echo
} >> "${LOG_FILE}"
sync

# Follow the kernel journal from now forward. --output=short-iso gives
# a sortable timestamp. stdbuf -oL keeps grep's output line-buffered so
# matches reach the snapshot loop immediately.
stdbuf -oL journalctl -k --follow --output=short-iso --no-pager \
  | stdbuf -oL grep -E "${MATCH}" \
  | while IFS= read -r line; do
      emit_snapshot "${line}"
    done
