<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="grunt_mast">

  <!--
    Sensor mast subsystem for Grunt platform.
    Mounts to chassis top_plate. Houses IMU, GPS antenna, and 3D LiDAR.

    Mast geometry: symmetric trapezoid prism (STL mesh)
      Base: 0.332m (Y), Top: 0.12m (Y), Height: 0.42m (Z), Depth: 0.05m (X)
    Orientation: +X forward, +Y left, +Z up (ROS convention)
    Origin at center of mast base (bottom).

    Usage: xacro mast.xacro prefix:=grunt1/mast/
  -->

  <xacro:arg name="prefix" default=""/>

  <!-- Materials -->
  <material name="$(arg prefix)mast_grey">
    <color rgba="0.75 0.75 0.75 0.6"/>
  </material>
  <material name="$(arg prefix)black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="$(arg prefix)white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>

  <!-- ============ LINKS ============ -->

  <!-- Mast structure: trapezoid prism -->
  <link name="$(arg prefix)base_link">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0.21" rpy="0 0 0"/>
      <inertia ixx="0.012" ixy="0" ixz="0"
               iyy="0.012" iyz="0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://grunt_description/meshes/mast_trapezoid.stl"/>
      </geometry>
      <material name="$(arg prefix)mast_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.21" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.226 0.42"/>
      </geometry>
    </collision>
  </link>

  <!-- GPS antenna: 56mm x 56mm x 25mm black block, centered on mast top -->
  <link name="$(arg prefix)gps_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.0125"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry>
        <box size="0.056 0.056 0.025"/>
      </geometry>
      <material name="$(arg prefix)black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.0125" rpy="0 0 0"/>
      <geometry>
        <box size="0.056 0.056 0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- BNO055 IMU: 50mm x 25mm x 10mm white PCB -->
  <link name="$(arg prefix)imu_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0"
               iyy="1e-6" iyz="0"
               izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.050 0.025 0.010"/>
      </geometry>
      <material name="$(arg prefix)white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.050 0.025 0.010"/>
      </geometry>
    </collision>
  </link>

  <!-- Unitree L2 4D LiDAR -->
  <link name="$(arg prefix)lidar_3d_link">
    <inertial>
      <mass value="0.195"/>
      <origin xyz="0 0 0.02"/>
      <inertia ixx="1e-4" ixy="0" ixz="0"
               iyy="1e-4" iyz="0"
               izz="1e-4"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://grunt_description/meshes/unitreeL2.stl"/>
      </geometry>
      <material name="$(arg prefix)black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.016" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0375" length="0.032"/>
      </geometry>
    </collision>
  </link>

  <!-- ============ JOINTS ============ -->
  <!-- All sensor positions relative to mast base_link origin (center of mast bottom) -->

  <!-- GPS antenna: centered on mast top surface -->
  <joint name="$(arg prefix)gps_joint" type="fixed">
    <origin xyz="0 0 0.42" rpy="0 0 0"/>
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)gps_link"/>
  </joint>

  <!-- BNO055 IMU: 22cm above mast base, 5cm to the right (-Y) of center -->
  <joint name="$(arg prefix)imu_joint" type="fixed">
    <origin xyz="0 -0.05 0.22" rpy="0 0 0"/>
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)imu_link"/>
  </joint>

  <!-- Unitree L2 LiDAR: on shelf angled 20deg forward-down,
       4cm forward (+X) of mast center, 34cm above mast base.
       Pitch = -0.3491 rad tilts front of LiDAR downward. -->
  <joint name="$(arg prefix)lidar_3d_joint" type="fixed">
    <origin xyz="0.04 0 0.34" rpy="0 -0.3491 0"/>
    <parent link="$(arg prefix)base_link"/>
    <child link="$(arg prefix)lidar_3d_link"/>
  </joint>

</robot>
