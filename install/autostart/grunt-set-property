#!/usr/bin/env bash
# grunt-set-property — switch the active grunt property and restart the stack.
#
# Property is the per-site folder name under <grunt_missions>/properties/<name>/.
# Switching reloads grunt.service and (via BindsTo) grunt-nav@<mode>.service,
# so all consumers (bt_runner, waypoint_recorder, mission_overlay, joy_estop)
# pick up the new missions_dir on the next start.
#
# Usage:
#   grunt-set-property <property_name>
#   grunt-set-property --show
#
# Examples:
#   sudo grunt-set-property dallas_makerspace
#   grunt-set-property --show     # prints the currently-set property
#
# Implementation: rewrites /etc/default/grunt with GRUNT_PROPERTY=<name>,
# then `systemctl restart grunt.service`. ~30s of nav downtime per switch
# is the same cost as any planned grunt restart.
#
# Install:
#   sudo install -m 0755 \
#     /home/karim/ros2_ws/src/grunt/install/autostart/grunt-set-property \
#     /usr/local/bin/grunt-set-property

set -euo pipefail

ENV_FILE=/etc/default/grunt
SERVICE=grunt.service

show_current() {
  if [[ -f "$ENV_FILE" ]]; then
    grep -E '^GRUNT_PROPERTY=' "$ENV_FILE" | sed 's/^GRUNT_PROPERTY=//' || true
  fi
  # Fall back to whatever the running service inherited.
  systemctl show -p Environment "$SERVICE" 2>/dev/null \
    | tr ' ' '\n' | grep '^GRUNT_PROPERTY=' | sed 's/^GRUNT_PROPERTY=//' \
    | head -1 || true
}

if [[ "${1:-}" == "--show" || "${1:-}" == "-s" ]]; then
  current=$(show_current)
  echo "${current:-(unset — service uses Environment= default)}"
  exit 0
fi

if [[ $# -ne 1 || "${1:-}" =~ ^- ]]; then
  echo "Usage: $0 <property_name> | --show" >&2
  exit 2
fi

property="$1"

# Sanity: property must look like a directory name. No slashes, no dots
# leading. Loose pattern — properties_root/<property> is the only path
# that actually constrains this.
if ! [[ "$property" =~ ^[A-Za-z0-9_][A-Za-z0-9_-]*$ ]]; then
  echo "Refusing: '$property' doesn't look like a property folder name." >&2
  echo "Expected [A-Za-z0-9_][A-Za-z0-9_-]*" >&2
  exit 2
fi

if [[ $EUID -ne 0 ]]; then
  echo "This command writes $ENV_FILE and restarts $SERVICE — re-run with sudo." >&2
  exit 1
fi

# Atomic-ish write: tempfile + mv keeps a sane env file even if the
# system loses power between writes.
tmp=$(mktemp /etc/default/grunt.XXXXXX)
trap 'rm -f "$tmp"' EXIT
{
  echo "# Managed by grunt-set-property; edits are preserved across upgrades."
  echo "GRUNT_PROPERTY=$property"
} > "$tmp"
chmod 0644 "$tmp"
mv "$tmp" "$ENV_FILE"
trap - EXIT

echo "Set GRUNT_PROPERTY=$property in $ENV_FILE"
echo "Restarting $SERVICE..."
systemctl restart "$SERVICE"
echo "Done. Stack restarting; allow ~30s for Nav2 to re-activate."
